# Prospect Intelligence Platform

# Optional: override storage root (defaults to ./storage locally, /tmp on Vercel)
# STORAGE_ROOT=

# Required on Vercel for durable uploads/reports across serverless instances.
# Vercel Dashboard → Storage → Blob → Create → Connect to this project
# (injects BLOB_READ_WRITE_TOKEN automatically)
# BLOB_READ_WRITE_TOKEN=

# Match your Blob store mode. Default is private (recommended).
# BLOB_ACCESS=private
# BLOB_ACCESS=public
